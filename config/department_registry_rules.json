      "capabilities": [
        "quality_gate_report",
        "atlas_governance_check",
        "atlas_verify",
        "evidence_collector_readiness",
        "mcp_readiness_check",
        "skill_registry_index_first_readiness"
      ],
      "must_not_do": [
        "Do not hide failing evidence behind optimistic summaries.",
        "Do not treat advisory posture as permission to execute risky integrations."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py",
        "python tools/mcp_readiness_check.py"
