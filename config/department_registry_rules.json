      "capabilities": [
        "market_research_benchmark",
        "skill_improvement_review",
        "repo_improvement_scout"
      ],
      "must_not_do": [
        "Do not adopt external repos by popularity alone.",
        "Do not scrape, install or activate external runtimes automatically."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py"
      ],
