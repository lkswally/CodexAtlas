  "departments": {
    "product": {
      "status": "active",
      "purpose": "Clarify problem, audience, scope, product promise and decision framing before implementation expands.",
      "activate_when": [
        "A project or request still needs scope, problem or value validation.",
        "Atlas has to rank what should happen first across product, UX and engineering work."
      ],
      "required_inputs": [
        "project_type",
        "objective",
        "problem_statement",
        "target_audience"
      ],
      "expected_outputs": [
        "priority framing",
        "decision notes",
        "business idea or scope posture",
        "change proposal posture when scope is medium or large"
      ],
      "capabilities": [
        "business_idea_simulation_readiness",
        "priority_engine",
        "decision_feedback",
        "change_proposal_readiness"
      ],
      "must_not_do": [
        "Do not invent business evidence or market traction.",
        "Do not approve large scope changes without explicit proposal discipline."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py"
      ],
      "handoff_to": [
        "research",
        "web_ux",
        "engineering",
        "qa_governance"
      ],
      "project_type_fit": [
        "frontend_app",
        "internal_tool",
        "ai_agent_system",
        "atlas-factory-core"
      ],
      "signal_triggers": [
        "idea",
        "validate",
        "scope",
        "proposal"
      ]
    },
    "web_ux": {
      "status": "active",
      "purpose": "Govern visual direction, usability, structure, copy fit and browser-truth readiness for user-facing surfaces.",
      "activate_when": [
        "The project is frontend or public-facing.",
        "There are layout, visual drift, hierarchy, CTA or responsive concerns."
      ],
      "required_inputs": [
        "project_type",
        "target_audience",
        "visual_direction",
        "primary_cta"
      ],
      "expected_outputs": [
        "visual direction posture",
        "design-system recommendation",
        "copy and brand readiness",
        "visual fidelity or browser-truth guidance"
      ],
      "capabilities": [
        "ui_ux_design_system_readiness",
        "visual_fidelity_judge",
        "copywriting_conversion_readiness",
        "brand_strategy_readiness",
        "chrome_devtools_mcp_readiness"
      ],
      "must_not_do": [
        "Do not claim public-ready UI without evidence.",
        "Do not activate browser automation or MCPs automatically."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py",
        "python tools/mcp_readiness_check.py"
      ],
      "handoff_to": [
        "growth_marketing",
        "engineering",
        "qa_governance"
      ],
      "project_type_fit": [
        "frontend_app",
        "landing_page",
        "marketing_site",
        "dashboard",
        "ui_surface",
        "internal_tool"
      ],
      "signal_triggers": [
        "layout",
        "visual",
        "responsive",
        "cta"
      ]
    },
    "automation_n8n": {
      "status": "active",
      "purpose": "Design, audit and stage n8n workflows safely before any real connection, execution or production write.",
      "activate_when": [
        "A request involves workflow design, webhook intake, email automation or Sheets-style persistence.",
        "Atlas is reviewing n8n exports, blueprints or offline JSON."
      ],
      "required_inputs": [
        "workflow_blueprint",
        "test_payload",
        "side_effect_boundaries"
      ],
      "expected_outputs": [
        "n8n automation readiness posture",
        "workflow blueprint",
        "importable inactive JSON",
        "manual import checklist"
      ],
      "capabilities": [
        "n8n_automation_readiness",
        "n8n_workflow_blueprint_generator",
        "n8n_workflow_json_generator"
      ],
      "must_not_do": [
        "Do not execute workflows or call live webhooks.",
        "Do not bind real credentials or activate workflows automatically."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py"
      ],
      "handoff_to": [
        "engineering",
        "qa_governance"
      ],
      "project_type_fit": [
        "internal_tool",
        "ai_agent_system",
        "backend_service"
      ],
      "signal_triggers": [
        "n8n",
        "workflow",
        "webhook",
        "automation"
      ]
    },
    "engineering": {
      "status": "active",
      "purpose": "Hold implementation, architecture, runtime compatibility and repository-shape decisions inside governed engineering boundaries.",
      "activate_when": [
        "A task touches code, architecture, executor/runtime compatibility or deep repo navigation.",
        "Atlas needs to decide whether implementation is safe to proceed."
      ],
      "required_inputs": [
        "project_type",
        "objective",
        "code_or_structure_context"
      ],
      "expected_outputs": [
        "implementation posture",
        "repo graph recommendation",
        "runtime compatibility posture",
        "change proposal or execution guidance"
