      "signal_triggers": [
        "architecture",
        "code",
        "runtime",
        "build"
      ]
    },
    "growth_marketing": {
      "status": "active",
      "purpose": "Tighten positioning, trust, CTA integrity and anti-generic public messaging without inventing growth claims.",
      "activate_when": [
        "The surface is landing-like, public-facing or conversion-sensitive.",
        "Atlas needs to review positioning, copy, CTAs or branded messaging."
      ],
      "required_inputs": [
        "target_audience",
        "problem_statement",
        "value_proposition",
        "primary_cta"
      ],
      "expected_outputs": [
        "copywriting conversion posture",
        "brand strategy posture",
        "market framing or benchmark notes"
      ],
      "capabilities": [
        "copywriting_conversion_readiness",
        "brand_strategy_readiness",
        "market_research_benchmark"
      ],
      "must_not_do": [
        "Do not promise conversion, revenue or growth guarantees.",
        "Do not use hype or generic AI copy as evidence."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py"
      ],
      "handoff_to": [
        "web_ux",
