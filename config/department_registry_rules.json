    "research": {
      "status": "active",
      "purpose": "Benchmark references, external skills and capability radar without turning Atlas into trend-following automation.",
      "activate_when": [
        "A request needs comparative research, reference evaluation or curated external-radar scoring.",
        "Atlas has to decide whether an external pattern is already covered, useful later or unsafe."
      ],
      "required_inputs": [
        "research_goal",
        "comparison_scope"
      ],
      "expected_outputs": [
        "benchmark report",
        "external skill fit decision",
        "watchlist or adoption recommendation"
