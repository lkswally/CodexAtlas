        "Whenever a change needs validation, evidence or governance review."
      ],
      "required_inputs": [
        "project_path",
        "scope_declaration"
      ],
      "expected_outputs": [
        "quality gate report",
        "governance result",
        "evidence posture",
        "recommended next action"
