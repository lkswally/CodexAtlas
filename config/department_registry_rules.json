      "capabilities": [
        "repo_graph_readiness",
        "codex_runtime_compatibility_check",
        "change_proposal_readiness",
        "atlas_codex_executor"
      ],
      "must_not_do": [
        "Do not widen runtime or dependency surface without explicit approval.",
        "Do not bypass governance for architecture, security or execution-risk work."
      ],
      "required_checks": [
        "python tools/atlas_verify.py",
        "python tools/atlas_governance_check.py"
      ],
      "handoff_to": [
        "qa_governance"
      ],
      "project_type_fit": [
        "backend_service",
        "internal_tool",
        "ai_agent_system",
        "atlas-factory-core"
